# Supabase
# Use the project root URL, not the /rest/v1 URL.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Gemini
GEMINI_API_KEY_1=replace_me
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=
GEMINI_CHAT_MODEL=gemma-4-31b-it
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
EMBEDDING_PROVIDER=huggingface
HF_TOKEN=
HF_EMBEDDING_MODEL=AITeamVN/Vietnamese_Embedding
HF_EMBEDDING_DEVICE=cpu
HF_EMBEDDING_BATCH_SIZE=16

# Data source
DVC_BASE_URL=https://thutuc.dichvucong.gov.vn
DVC_REST_PATH=/jsp/rest.jsp
DVC_HCMC_AGENCY_ID=411312
DVC_HCMC_AGENCY_NAME=UBND Thành phố Hồ Chí Minh
DVC_HCMC_AGENCY_CODE=H29
DVC_REQUEST_TIMEOUT_SECONDS=60
DVC_MAX_RETRIES=5
DVC_RETRY_BACKOFF_SECONDS=1.5
DVC_PAGE_DELAY_SECONDS=0.5

# Backend
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_HOURS=24
SCHEDULER_MARK_INACTIVE=true
SCHEDULER_VECTOR_FORCE=false
SCHEDULER_RAG_SYNC_ENABLED=false
SCHEDULER_BM25_SYNC_ENABLED=false
SCHEDULER_PINECONE_BATCH_SIZE=32
SCHEDULER_RAG_PROGRESS_EVERY=100

# RAG retrieval
VECTOR_STORE=pinecone
PYTHON_TEXTRACT_ENABLED=true
CHUNK_TOKEN_LIMIT=512
CHUNK_OVERLAP_TOKENS=50
PINECONE_API_KEY=
PINECONE_INDEX_NAME=hcm-govbot
PINECONE_NAMESPACE=dev
PINECONE_METRIC=cosine
RETRIEVAL_BM25_TOP_N=30
RETRIEVAL_DENSE_TOP_N=30
RETRIEVAL_RRF_K=60
RETRIEVAL_RERANK_TOP_N=8
RETRIEVAL_FINAL_TOP_K=8
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_MAX_LATENCY_SECONDS=2
BM25_TOKENIZER=underthesea
BM25_CACHE_PATH=.rag_cache/bm25_cache.pkl
BM25_ALLOW_LIVE_BUILD=false
CHAT_RETRIEVE_EVERY_TURN=true
CHAT_REWRITE_WHEN_AMBIGUOUS=true

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace_me
# Configure Google Client ID/Secret in Supabase Dashboard -> Authentication -> Providers -> Google.
# Do not put Google Client Secret in frontend env.
